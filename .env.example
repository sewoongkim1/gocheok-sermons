# 로컬 원커맨드(scripts/add-local.mjs)용 키 — 이 파일을 복사해 ".env" 로 저장하고 값을 채우세요.
# .env 는 커밋 금지(.gitignore에 포함). 값은 GitHub 저장소 Settings → Secrets 와 동일합니다.

# Claude(설교 요약·핵심·맺음말·나레이션 대본 생성)
ANTHROPIC_API_KEY=sk-ant-...

# Azure 음성(3분 요약 MP3)
AZURE_SPEECH_KEY=...
AZURE_SPEECH_REGION=koreacentral

# 설교 DB 적재(sermon 함수 관리자 비번 = SERMON_ADMIN)
SERMON_ADMIN=...

# (선택) 모델/음성 조정
# SERMON_MODEL=claude-opus-4-8
# AZURE_VOICE=ko-KR-SunHiNeural
